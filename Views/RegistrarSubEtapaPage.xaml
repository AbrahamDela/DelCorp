<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DelCorp.ViewModels"
             xmlns:models="clr-namespace:DelCorp.Models"
             xmlns:converters="clr-namespace:DelCorp.Converters"
             x:Class="DelCorp.Views.RegistrarSubEtapaPage"
             x:DataType="viewmodels:RegistrarSubEtapaViewModel"
             Title="Registrar Sub-Etapas">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Label Text="Registrar Nueva Sub-Etapa" FontAttributes="Bold" FontSize="Medium"/>

            <Picker Title="Seleccionar Actividad para Sub-Etapa"
                    ItemsSource="{Binding ActividadesDisponibles}"
                    ItemDisplayBinding="{Binding NombreActividad}"
                    SelectedItem="{Binding SelectedActividad}" />

            <Entry Placeholder="Nombre de Nueva Actividad (si aplica)"
                   Text="{Binding NombreNuevaActividad}"
                   IsVisible="{Binding MostrarCampoNuevaActividad}" />

            <Picker Title="Categoría para Nueva Actividad"
                    ItemsSource="{Binding CategoriasActividad}"
                    ItemDisplayBinding="{Binding NombreCategoriaActividad}"
                    SelectedItem="{Binding SelectedCategoriaActividad}"
                    IsVisible="{Binding MostrarCampoNuevaActividad}"
                    IsEnabled="{Binding PickersForNewActivityEnabled}" />

            <Label Text="{Binding UnidadMedidaActividadSeleccionada}" IsVisible="{Binding MostrarCampoNuevaActividad, Converter={StaticResource InverseBoolConverter}}" />


            <Entry Placeholder="Cantidad de la Sub-Etapa" Keyboard="Numeric" Text="{Binding CantidadSubEtapa}" />
            <Entry Placeholder="Días Calendario Estimados" Keyboard="Numeric" Text="{Binding DiasCalSubEtapa}" />
            <Button Text="Guardar Sub-Etapa" Command="{Binding GuardarSubEtapaCommand}" IsEnabled="{Binding IsNotBusy}"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="Sub-Etapas Registradas" FontAttributes="Bold" FontSize="Medium" Margin="0,20,0,0"/>

            <Button Text="Guardar Orden de Sub-Etapas"
                    Command="{Binding SaveSubEtapaOrderChangesCommand}"
                    IsVisible="{Binding HasPendingSubEtapaOrderChanges}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="OrangeRed" TextColor="White" Margin="0,5,0,5"/>

            <CollectionView ItemsSource="{Binding SubEtapas}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SubEtapa">
                        <Frame Padding="10" Margin="0,5" CornerRadius="5" BorderColor="LightGray">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="5">
                                <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Sub-Etapa "/>
                                            <Span Text="{Binding NumeroSubEtapa}"/>
                                            <Span Text=": "/>
                                            <Span Text="{Binding Actividad.NombreActividad}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Button Grid.Row="0" Grid.Column="1" Text="▲" FontSize="Small" Padding="5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RegistrarSubEtapaViewModel}}, Path=MoveSubEtapaUpCommand}"
                                        CommandParameter="{Binding .}"/>
                                <Button Grid.Row="0" Grid.Column="2" Text="▼" FontSize="Small" Padding="5"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RegistrarSubEtapaViewModel}}, Path=MoveSubEtapaDownCommand}"
                                        CommandParameter="{Binding .}"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="{Binding CantidadSubEtapa, StringFormat='Cantidad: {0:N2}'}" />
                                <Label Grid.Row="2" Grid.Column="0" Text="{Binding TotalSubEstapa, StringFormat='Total Calculado: C{0:C}'}" />

                                <Label Grid.Row="3" Grid.Column="0" Text="{Binding MontoEjeSubEtapa, StringFormat='Ejecutado: {0:C}'}" TextColor="Green" />
                                <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Text="Registrar Uso de Recursos"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RegistrarSubEtapaViewModel}}, Path=NavigateToRegistroRecursosCommand}"
                                        CommandParameter="{Binding .}" Margin="0,5,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Text="No hay sub-etapas registradas para esta etapa."
                   IsVisible="{Binding SubEtapas.Count, Converter={StaticResource InverseBoolConverter}}"
                   HorizontalOptions="CenterAndExpand" Margin="0,10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>