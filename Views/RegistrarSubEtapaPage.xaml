<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DelCorp.ViewModels"
             xmlns:model="clr-namespace:DelCorp.Models"
             x:Class="DelCorp.Views.RegistrarSubEtapaPage"
             x:DataType="vm:RegistrarSubEtapaViewModel"
             Title="Registrar Sub-Etapas">
    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="20">

            <Label Text="Nueva Sub-Etapa" FontAttributes="Bold" FontSize="Medium"/>
            <Entry Text="{Binding ActividadSubEtapa}" Placeholder="Actividad de la Subetapa" />
            <Entry Text="{Binding CantidadSubEtapa}" Placeholder="Cantidad" Keyboard="Numeric" />
            <Picker Title="Unidad de Medida (Opcional)"
                    ItemsSource="{Binding DisponibleUniMedRe}"
                    ItemDisplayBinding="{Binding NombreUniMedRe}" 
                    SelectedItem="{Binding SelectedUniMedRe}" />

            <Button Text="Guardar Subetapa" Command="{Binding GuardarSubEtapaCommand}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>

            <Line StrokeThickness="1" Margin="0,20"/>

            <Label Text="Sub-Etapas Registradas" FontAttributes="Bold" FontSize="Medium"/>
            <CollectionView ItemsSource="{Binding SubEtapas}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:SubEtapa">
                        <Frame Padding="10" Margin="0,5" BorderColor="LightGray" CornerRadius="5">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                <Label Grid.Row="0" Grid.Column="0" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Actividad: " FontAttributes="Bold"/>
                                            <Span Text="{Binding ActividadSubEtapa}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="1" Grid.Column="0">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Cantidad: " FontAttributes="Bold"/>
                                            <Span Text="{Binding CantidadSubEtapa}"/>
                                            <Span Text="{Binding UniMedida.AbreviaturaUniMedRe, StringFormat=' {0}', TargetNullValue=''}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                               <Label Grid.Row="2" Grid.Column="0" >
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Total: C$" FontAttributes="Bold"/>
                                            <Span Text="{Binding TotalSubEstapa, StringFormat='{0:N2}'}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                                        Text="Recursos" 
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RegistrarSubEtapaViewModel}}, Path=NavigateToRegistrarRecursosCommand}"
                                        CommandParameter="{Binding .}"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No hay sub-etapas registradas para esta etapa." HorizontalOptions="Center" VerticalOptions="Center" Margin="20"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>