<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
             x:Class="DelCorp.Views.UserProfilePage"
             Title="Perfil de Usuario">

    <ScrollView>
        <VerticalStackLayout 
            Spacing="20" 
            Padding="20" 
            VerticalOptions="Start">

            <!-- Información de Perfil -->
            <Frame>
                <VerticalStackLayout>
                    <!-- Avatar y Nombre -->
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">

                        <Label
                            Grid.Column="1"
                            Text="{Binding UserProfile.Name}"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Primary}"/>

                        <Label 
                            Grid.Column="1" 
                            Grid.Row="1"
                            Text="{Binding UserProfile.Email}"
                            TextColor="Gray"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Detalles de la Cuenta 
            <Frame>
                <VerticalStackLayout>
                    <Label Text="Detalles de la Cuenta" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource Primary}"/>

                    <StackLayout Orientation="Horizontal" Margin="0,10">
                        <Label Text="Fecha de Registro:"/>
                        <Label 
                            Text="{Binding UserProfile.CreatedAt, StringFormat='{0:dd/MM/yyyy}'}"/>
                    </StackLayout>

                    <StackLayout Orientation="Horizontal">
                        <Label Text="ID de Usuario:"/>
                        <Label 
                            Text="{Binding UserProfile.Id}"/>
                    </StackLayout>
                </VerticalStackLayout>
            </Frame> -->

            <!-- Acciones de Perfil -->
            <Frame>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Acciones" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="{StaticResource Primary}"/>

                    <!-- Botón Cerrar Sesión -->
                    <Button 
                        Text="Cerrar Sesión"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="Red"
                        TextColor="White"
                        CornerRadius="10"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Indicador de Carga -->
            <ActivityIndicator 
                IsRunning="{Binding IsLoading}"
                Color="{StaticResource Secondary}"
                IsVisible="{Binding IsLoading}"/>

            <!-- Mensaje de Error -->
            <Label 
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                HorizontalOptions="Center"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>