<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DelCorp.ViewModels"
             x:Class="DelCorp.Views.LoginPage"
             Title="Iniciar Sesión">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,0" VerticalOptions="Center">

            <Image Source="logo.png" HeightRequest="100" Aspect="AspectFit"
                   Margin="0,20,0,20"/>

            <Frame Padding="20" CornerRadius="10" HasShadow="True" BorderColor="LightGray">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Bienvenido" FontSize="Large" FontAttributes="Bold" HorizontalOptions="Center"/>

                    <Entry Placeholder="Correo Electrónico"
                           Text="{Binding Email}"
                           Keyboard="Email" />

                    <Entry Placeholder="Contraseña"
                           Text="{Binding Password}"
                           IsPassword="True" />

                    <Button Text="Iniciar Sesión"
                            Command="{Binding LoginCommand}" 
                            IsEnabled="{Binding IsLoginEnabled}"
                            BackgroundColor="Black"
                            TextColor="White"
                            CornerRadius="5"/>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Red"
                           IsVisible="{Binding HasError}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            </VerticalStackLayout>
    </ScrollView>
</ContentPage>