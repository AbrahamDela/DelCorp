<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:DelCorp.ViewModels"
             xmlns:models="clr-namespace:DelCorp.Models"
             x:DataType="viewmodel:ManageBudgetViewModel"
             x:Class="DelCorp.Views.ManageBudget"
             Title="Gestionar Presupuesto">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Nombre del Presupuesto Row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Entry Placeholder="Nombre del Presupuesto"
                   TextTransform="Uppercase"/>
            <Button Grid.Column="1" 
                    Text="x" 
                    FontSize="24"
                    TextColor="Black"
                    BackgroundColor="Transparent"/>
        </Grid>

        <!-- Fecha Inicio y Fin -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Picker Grid.Column="0"
                    Title="Estado"
                    SelectedItem="{Binding EstadoPresupuesto}">
                <Picker.Items>
                    <x:String>PENDIENTE</x:String>
                    <x:String>APROBADO</x:String>
                    <x:String>RECHAZADO</x:String>
                </Picker.Items>
            </Picker>
            <DatePicker Grid.Column="1" 
                        Date="{Binding FechaInicioPresupuesto}"/>
            <DatePicker Grid.Column="2" 
                        Date="{Binding FechaFinPresupuesto}"/>
        </Grid>

        <Label Text="Etapas"
               Style="{StaticResource TitleSmall}"/>

        <!-- Etapas ListView con boton de eliminación -->
        <ListView ItemsSource="{Binding Etapas}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Eliminar" 
                                               BackgroundColor="Red"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ManageBudgetViewModel}}, Path=DeleteEtapaCommand}"
                                               CommandParameter="{Binding .}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="{Binding NumeroEtapa}"/>
                                <Label Grid.Column="1" Text="{Binding ActividadEtapa}"/>
                                <Label Grid.Column="2" Text="{Binding UnidadMedida}"/>
                                <Label Grid.Column="3" Text="{Binding CantidadEtapa}"/>
                            </Grid>
                        </SwipeView>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Agregar Nueva Etapa -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Entry Grid.Column="0" 
                   Text="{Binding NumeroEtapa}"
                   Placeholder="No. Etapa"
                   Keyboard="Numeric"/>

            <Picker Grid.Column="1"
                    Title="Unidad"
                    SelectedItem="{Binding UnidadMedida}">
                <Picker.Items>
                    <x:String>M2</x:String>
                    <x:String>ML</x:String>
                    <x:String>M3</x:String>
                    <x:String>C/U</x:String>
                </Picker.Items>
            </Picker>

            <Entry Grid.Column="2" 
                   Text="{Binding CantidadEtapa}"
                   Placeholder="Cantidad"
                   Keyboard="Numeric"/>
        </Grid>

        <!-- Actividad -->
        <Entry Placeholder="Actividad"
               Text="{Binding ActividadEtapa}"
               TextTransform="Uppercase"/>

        <!-- Agregar Etapa -->
        <Button Text="Agregar Etapa" 
                Command="{Binding AddEtapaCommand}"
                BackgroundColor="{StaticResource Success}" 
                TextColor="White"/>

        <!-- Botones de accioon -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Text="Cancelar" 
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="{StaticResource Error}"
                    TextColor="White"/>

            <Button Grid.Column="1" 
                    Text="Guardar" 
                    Command="{Binding SavePresupuestoCommand}"
                    BackgroundColor="{StaticResource Success}"
                    TextColor="White"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>